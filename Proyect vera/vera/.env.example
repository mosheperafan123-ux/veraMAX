# Copia este archivo a .env.local y ajusta los valores.

# — Evolution API (WhatsApp, Docker local) —
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=cambia-esta-clave
EVOLUTION_INSTANCE_NAME=webleads

# — Anti-baneo —
# Límite diario de mensajes. Semana 1 sugerida: 5–8 (calentamiento).
DAILY_MESSAGE_LIMIT=25

# — Webhook de respuestas entrantes (auto-actualización del CRM) —
# URL que Evolution (en Docker) llama al recibir un mensaje. Desde el contenedor
# el host es host.docker.internal. Déjalo así si el app corre en el puerto 3000.
APP_WEBHOOK_URL=http://host.docker.internal:3000/api/webhook/evolution

# — Auto-limpieza de páginas —
# Días sin respuesta tras los cuales se elimina la página del lead (y se republica).
DEMO_EXPIRE_DAYS=3

# — Avisos a Moshe —
# Número (tu WhatsApp personal) al que el sistema te avisa cuando un cliente responde.
NOTIFY_PHONE=3153611499

# — Seguimiento por plantilla (sin IA) —
# Horas sin respuesta tras las cuales el lead aparece para recordatorio, y máximo por lead.
FOLLOWUP_HOURS=48
FOLLOWUP_MAX=2

# — Modo prueba (SEGURIDAD) —
# Con TEST_MODE=true, TODOS los envíos van solo a TEST_PHONE y NO se marca el lead real.
# Mantén esto en true hasta terminar el software. Ponlo en false para enviar de verdad.
TEST_MODE=true
TEST_PHONE=3153611499

# — App —
# URL base usada en los links de los demos dentro de los mensajes de WhatsApp.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Marca que aparece en el footer de los demos.
NEXT_PUBLIC_VERA_BRAND=Vera

# — Hosting de demos (GitHub Pages, gratis y permanente) —
# Configúralo una sola vez (ver README → "Publicar demos online").
# Con esto, los demos se envían con una URL limpia tipo https://tu-usuario.github.io/vera-demos/13/
GITHUB_TOKEN=
GITHUB_REPO=tu-usuario/vera-demos
DEMOS_PUBLIC_BASE=https://tu-usuario.github.io/vera-demos
# Opcional (autor de los commits del deploy)
GIT_AUTHOR_NAME=Vera Bot
GIT_AUTHOR_EMAIL=vera@local
